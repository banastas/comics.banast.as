{
  "name": "comic-collection-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run generate:sitemap && vite build && npm run generate:static-pages",
    "check": "npm run validate:data && npm run typecheck && npm run lint && npm run test:run && npm run build && npm run verify:static-pages",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:app && npm run typecheck:functions && npm run typecheck:node",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:functions": "tsc -p tsconfig.functions.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:static-pages": "node scripts/generate-static-pages.mjs",
    "verify:static-pages": "node scripts/verify-static-pages.mjs",
    "validate:data": "node scripts/validate-data.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.0.17",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "terser": "^5.44.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
